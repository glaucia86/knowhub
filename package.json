{
  "name": "knowhub",
  "version": "0.2.1",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:core",
    "build:core": "turbo run build --filter=!@knowhub/web",
    "build:web": "npm run build -w @knowhub/web",
    "build:all": "npm run build:core && npm run build:web",
    "dev": "npm run dev:core",
    "dev:core": "turbo run dev --filter=!@knowhub/web",
    "dev:web": "npm run dev -w @knowhub/web",
    "dev:all": "turbo run dev",
    "dev:local": "npm run env:setup && docker compose up -d && npm run dev",
    "env:setup": "node scripts/env-setup.js",
    "gen:architecture": "node scripts/gen-architecture.mjs",
    "gen:architecture-src": "node scripts/gen-architecture-excalidraw.mjs",
    "db:generate": "npm run db:generate -w @knowhub/api",
    "db:migrate": "npm run db:migrate -w @knowhub/api",
    "db:seed": "npm run db:seed -w @knowhub/api",
    "db:reset": "npm run db:reset -w @knowhub/api",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage --filter=@knowhub/api",
    "test:watch": "turbo run test:watch",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "roughjs": "^4.6.6",
    "turbo": "^2.8.14",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "npm@11.7.0"
}
