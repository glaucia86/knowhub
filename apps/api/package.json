{
  "name": "@knowhub/api",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node dist/main.js",
    "build": "npm run build -w @knowhub/shared-types && npm run build -w @knowhub/shared-utils && tsc -p tsconfig.json",
    "test": "npm run build && cd dist && node --test --test-concurrency=1",
    "test:coverage:auth": "npm run build && node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-include=dist/modules/auth/auth.service.js --test-coverage-include=dist/modules/auth/refresh-token.repository.js --test-coverage-include=dist/modules/auth/auth-rate-limit.service.js --test-coverage-exclude=dist/modules/auth/*.spec.js --test-coverage-lines=90 --test-coverage-branches=90 --test-coverage-functions=90 dist/modules/auth/auth.token.int.spec.js dist/modules/auth/auth.refresh.int.spec.js dist/modules/auth/auth.logout.int.spec.js dist/modules/auth/auth.service.int.spec.js dist/modules/auth/refresh-token.repository.int.spec.js dist/modules/auth/auth-audit.int.spec.js",
    "test:coverage:health": "npm run build && node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-include=dist/modules/health/ollama-health.indicator.js --test-coverage-include=dist/modules/health/drizzle-health.indicator.js --test-coverage-exclude=dist/modules/health/*.spec.js --test-coverage-lines=85 --test-coverage-branches=85 --test-coverage-functions=85 dist/modules/health/health.int.spec.js dist/modules/health/drizzle-health.int.spec.js",
    "test:coverage:settings": "npm run build && node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-include=dist/modules/settings/settings.service.js --test-coverage-include=dist/modules/settings/ai-provider.factory.js --test-coverage-include=dist/modules/settings/ollama-models.service.js --test-coverage-exclude=dist/modules/settings/*.spec.js --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 dist/modules/settings/settings.int.spec.js dist/modules/settings/settings-ai.int.spec.js dist/modules/settings/settings.service.int.spec.js dist/modules/settings/settings.provider.int.spec.js dist/modules/settings/ollama-models.int.spec.js",
    "test:coverage:knowledge": "npm run build && node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-include=dist/modules/knowledge/knowledge.service.js --test-coverage-include=dist/modules/knowledge/tags.service.js --test-coverage-include=dist/modules/knowledge/knowledge.helpers.js --test-coverage-exclude=dist/modules/knowledge/*.spec.js --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 dist/modules/knowledge/knowledge.service.spec.js dist/modules/knowledge/knowledge.lifecycle.spec.js dist/modules/knowledge/knowledge.helpers.spec.js dist/modules/knowledge/tags.service.spec.js",
    "test:coverage": "npm run test:coverage:auth && npm run test:coverage:health && npm run test:coverage:settings && npm run test:coverage:knowledge",
    "test:watch": "npm run test",
    "lint": "eslint src --ext .ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node ../../scripts/db-migrate.js",
    "db:seed": "node ../../scripts/db-seed.js",
    "db:reset": "node ../../scripts/db-reset.js"
  },
  "dependencies": {
    "@knowhub/shared-types": "0.1.0",
    "@knowhub/shared-utils": "0.1.0",
    "@mozilla/readability": "^0.6.0",
    "@nestjs/common": "^11.0.15",
    "@nestjs/core": "^11.1.16",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.61.2",
    "chardet": "^2.1.0",
    "cheerio": "^1.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "eventemitter2": "^6.4.9",
    "iconv-lite": "^0.7.0",
    "ioredis": "^5.8.2",
    "joi": "^18.0.1",
    "jsdom": "^28.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfjs-dist": "^5.4.296",
    "reflect-metadata": "^0.2.0",
    "remark": "^15.0.1",
    "strip-markdown": "^6.0.0",
    "validator": "^13.15.15",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0",
    "playwright": "^1.53.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.0",
    "@types/multer": "^2.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.18.1",
    "supertest": "^7.2.2"
  }
}
